# Copy to ".env" next to compose.yaml and fill in your values.
# Used by the kanban-backups NFS volume in compose.yaml.

# Your Ubiquiti NAS IP (or hostname).
NAS_HOST=10.0.0.10

# The NFS export path on the NAS for kanban backups, e.g. the share you create.
# This is the path as the NAS exports it (check the UNAS NFS/share settings).
NAS_BACKUP_EXPORT=/volume1/backups/kanban
